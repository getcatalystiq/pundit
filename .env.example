# Pundit Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# Database (Neon PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://user:password@host/pundit?sslmode=require

# =============================================================================
# Authentication (JWT)
# =============================================================================
JWT_SECRET=your-secret-key-at-least-32-characters-long

# =============================================================================
# Vercel Blob Storage (for chart images)
# =============================================================================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# =============================================================================
# Encryption (AES-256-GCM for tenant DB credentials)
# =============================================================================
ENCRYPTION_KEY=64-hex-character-string-representing-32-bytes-of-entropy-here

# =============================================================================
# AI Services (via Vercel AI SDK)
# =============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Application Settings
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3000
ENVIRONMENT=dev
# CRON_SECRET=your-cron-secret
# ALLOWED_DCR_DOMAINS=claude.ai,localhost,127.0.0.1
