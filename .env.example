# Pundit Local Development Environment Variables
#
# Copy this file to .env.local and update the values for local development.
# These are used by SAM local and the local development script.

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_REGION=us-east-1
AWS_PROFILE=default

# =============================================================================
# Aurora Database (Local Development)
# =============================================================================
# For local dev, you can use a local PostgreSQL instance or connect to Aurora
# Option 1: Local PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pundit
DATABASE_USER=pundit_admin
DATABASE_PASSWORD=localdevpassword

# Option 2: Use Aurora Data API (requires VPN/bastion to VPC)
# AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:pundit-dev-aurora-credentials
# AURORA_CLUSTER_ARN=arn:aws:rds:us-east-1:123456789:cluster:pundit-dev-cluster
# AURORA_DATABASE=pundit

# =============================================================================
# OpenAI (for embeddings)
# =============================================================================
# Option 1: Direct API key (local dev only)
OPENAI_API_KEY=sk-your-openai-api-key

# Option 2: Use Secrets Manager
# OPENAI_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:pundit-dev-openai-api-key

# =============================================================================
# Bedrock (for AI generation)
# =============================================================================
BEDROCK_REGION=us-east-1
# Override the model if needed (default: Claude Opus 4.5)
# BEDROCK_MODEL_ID=anthropic.claude-opus-4-5-20251101-v1:0

# =============================================================================
# OAuth Server
# =============================================================================
# Issuer URL - for local dev, this is the SAM local URL
OAUTH_ISSUER=http://localhost:3000

# JWT secret for local development (use a secure random string in production)
JWT_SECRET=local-dev-jwt-secret-change-in-production

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG

# =============================================================================
# Local Development Settings
# =============================================================================
# Enable debug mode for verbose logging
DEBUG=true

# CORS origins for local development (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Admin UI (if running locally)
# =============================================================================
VITE_API_URL=http://localhost:3000
